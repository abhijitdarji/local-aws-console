    "@aws-sdk/client-ecr-public": "^3.1051.0",
    "@aws-sdk/client-iam": "^3.1054.0",
    "@aws-sdk/client-lambda": "^3.540.0",
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/client-secrets-manager": "^3.543.0",
