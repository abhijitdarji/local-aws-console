{
  "name": "local-aws-console",
  "version": "2.0.0",
  "author": "Abhijit Darji",
  "description": "Local readonly AWS console",
  "engines": {
    "node": ">=22.22.1"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/abhijitdarji/local-aws-console.git"
  },
  "homepage": "https://github.com/abhijitdarji/local-aws-console",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "keywords": [
    "aws",
    "console",
    "localstack",
    "local",
    "development",
    "nextjs",
    "react",
    "cloudscape-design",
    "aws-multi-account"
  ],
